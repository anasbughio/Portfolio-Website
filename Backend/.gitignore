# ================= SECRETS & PASSWORDS =================
# NEVER commit these! They hold your database keys and JWT secrets.
.env
.env.*
*.pem

# ================= DEPENDENCIES =================
# Let the hosting provider (Render/AWS) install these freshly on their own server.
node_modules/

# ================= LOGS =================
# Generated by Node during runtime or application crashes.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ================= RUNTIME DATA =================
pids
*.pid
*.seed
*.pid.lock

# ================= COVERAGE & TESTING =================
coverage/
.nyc_output

# ================= OS & EDITOR FILES =================
# Hidden junk files created behind the scenes by VS Code, macOS, or Windows.
.DS_Store
.vscode/
*.suo
*.ntvs*
*.njsproj
Thumbs.db